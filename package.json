{
  "name": "acp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:client": "turbo run dev --filter=@acp/flamecast",
    "dev:server": "turbo run dev --filter=@acp/server",
    "build": "turbo run build",
    "start": "pnpm dev",
    "knip": "pnpm --filter @acp/flamecast run generate:routes && knip --config knip.json --workspace packages/flamecast --no-config-hints",
    "ci:lint": "pnpm lint && pnpm oxlint && pnpm format:check",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "oxlint": "oxlint --config .oxlintrc.json .",
    "oxlint:fix": "oxlint --config .oxlintrc.json --fix .",
    "format": "oxfmt --config .oxfmtrc.json --write .",
    "format:check": "oxfmt --config .oxfmtrc.json --check .",
    "fmt": "pnpm lint:fix && pnpm oxlint:fix && pnpm format",
    "psql:generate": "turbo run psql:generate --filter=@acp/flamecast",
    "test": "turbo run test",
    "test:api": "turbo run test --filter=@acp/flamecast",
    "test:api:coverage": "turbo run test:api:coverage --filter=@acp/flamecast",
    "check": "pnpm ci:lint && pnpm build && pnpm test:api:coverage && pnpm knip",
    "alchemy:deploy": "turbo run alchemy:deploy --filter=@acp/flamecast",
    "alchemy:dev": "turbo run alchemy:dev --filter=@acp/flamecast",
    "alchemy:destroy": "turbo run alchemy:destroy --filter=@acp/flamecast"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@eslint/js": "^10.0.1",
    "@libsql/client": "^0.17.2",
    "@tanstack/router-devtools": "^1.166.9",
    "@tanstack/router-plugin": "^1.166.14",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^10.0.3",
    "eslint-plugin-no-type-assertion": "^1.3.0",
    "globals": "^17.4.0",
    "knip": "^6.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.7.1",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.26.2"
}
