{
  "name": "acp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "pnpm dev",
    "knip": "knip --config knip.json --workspace packages/flamecast --no-config-hints",
    "ci:lint": "pnpm lint && pnpm format:check",
    "lint": "oxlint --config .oxlintrc.json --deny-warnings .",
    "lint:fix": "oxlint --config .oxlintrc.json --fix --fix-suggestions --deny-warnings .",
    "format": "oxfmt --config .oxfmtrc.json --write .",
    "format:check": "oxfmt --config .oxfmtrc.json --check .",
    "fmt": "pnpm lint:fix && pnpm format",
    "test": "turbo run test",
    "check": "pnpm ci:lint && pnpm build && pnpm test && pnpm knip",
    "clean": "git clean -ffdX",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ci:publish": "turbo run build && pnpm publish -r",
    "co": "sh -c 'git checkout \"$1\" && git pull && pnpm dev' --"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.11.17",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint-plugin-no-type-assertion": "^1.3.0",
    "knip": "^6.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.7.1",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {}
}
