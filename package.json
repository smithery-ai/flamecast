{
  "name": "acp",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts & vite",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build",
    "start": "node dist/index.js",
    "knip": "knip --no-config-hints",
    "ci:lint": "npm run lint && npm run format:check && npm run biome:lint",
    "biome:lint": "biome lint .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "fmt": "eslint . --fix --max-warnings 0 && biome format . --write",
    "psql:generate": "drizzle-kit generate --config src/flamecast/state-managers/psql/drizzle.config.ts",
    "test": "npm run test:api",
    "test:api": "vitest run --config vitest.integration.config.ts",
    "test:api:coverage": "vitest run --coverage --config vitest.integration.config.ts",
    "check": "npm run ci:lint && npm run build && npm run test:api:coverage",
    "alchemy:deploy": "alchemy deploy",
    "alchemy:dev": "alchemy dev",
    "alchemy:destroy": "alchemy destroy"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@base-ui/react": "^1.3.0",
    "@electric-sql/pglite": "^0.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-router": "^1.167.5",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.89.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.12.8",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.3",
    "recharts": "2.15.4",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "vite": "^8.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@cloudflare/vite-plugin": "^1.30.0",
    "@eslint/js": "^10.0.1",
    "@libsql/client": "^0.17.2",
    "@tanstack/router-devtools": "^1.166.9",
    "@tanstack/router-plugin": "^1.166.14",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^10.0.3",
    "eslint-plugin-no-type-assertion": "^1.3.0",
    "globals": "^17.4.0",
    "knip": "^6.0.1",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
