{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "react-jsx"
  },
  "include": [
    "src/cli.ts",
    "src/index.ts",
    "src/edge.ts",
    "src/worker.ts",
    "src/server/**/*.ts",
    "src/flamecast/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": ["src/client/**/*"]
}
