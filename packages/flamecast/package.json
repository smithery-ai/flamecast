{
  "name": "@flamecast/sdk",
  "version": "0.0.0",
  "bin": {
    "flamecast": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/flamecast/api.d.ts",
      "import": "./dist/flamecast/api.js"
    },
    "./server/app": {
      "types": "./dist/server/app.d.ts",
      "import": "./dist/server/app.js"
    },
    "./shared/session": {
      "types": "./dist/shared/session.d.ts",
      "import": "./dist/shared/session.js"
    },
    "./shared/session-host-protocol": {
      "types": "./dist/shared/session-host-protocol.d.ts",
      "import": "./dist/shared/session-host-protocol.js"
    },
    "./client": {
      "types": "./dist/client/api.d.ts",
      "import": "./dist/client/api.js"
    },
    "./runtime": {
      "types": "./dist/flamecast/runtime.d.ts",
      "import": "./dist/flamecast/runtime.js"
    },
    "./session-service": {
      "types": "./dist/flamecast/session-service.d.ts",
      "import": "./dist/flamecast/session-service.js"
    },
    "./storage": {
      "types": "./dist/flamecast/storage.d.ts",
      "import": "./dist/flamecast/storage.js"
    },
    "./runtimes/node": {
      "types": "./dist/flamecast/runtimes/node.d.ts",
      "import": "./dist/flamecast/runtimes/node.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:client && pnpm run build:package",
    "build:client": "vite build",
    "build:package": "tsc -p tsconfig.package.json && cp src/flamecast/agent.ts dist/flamecast/agent.ts",
    "generate:routes": "tsx scripts/generate-route-tree.ts",
    "start": "node dist/cli.js",
    "test": "vitest run --config vitest.integration.config.ts",
    "test:api:coverage": "vitest run --coverage --config vitest.integration.config.ts",
    "alchemy:deploy": "alchemy deploy",
    "alchemy:dev": "alchemy dev",
    "alchemy:destroy": "alchemy destroy"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-router": "^1.167.5",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.89.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.12.8",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.3",
    "recharts": "2.15.4",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "vite": "^8.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/router-generator": "1.166.15",
    "@tanstack/router-plugin": "^1.166.14",
    "@vitest/coverage-v8": "^4.1.0",
    "knip": "^6.0.1",
    "vitest": "^4.1.0"
  }
}
