{
  "name": "@flamecast/session-host",
  "version": "0.0.0",
  "bin": {
    "session-host": "./dist/index.js",
    "session-router": "./dist/router.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/router.ts",
    "dev:host": "tsx watch src/index.ts",
    "start": "node dist/router.js",
    "start:host": "node dist/index.js",
    "test": "vitest run",
    "build:package": "tsc",
    "docker:build": "tsc && docker build -t flamecast-session-host ."
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@flamecast/protocol": "workspace:*",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
