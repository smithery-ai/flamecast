{
  "name": "@flamecast/storage-psql",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.package.json && cp -r src/migrations dist/migrations",
    "test": "vitest run",
    "psql:generate": "drizzle-kit generate --config src/drizzle.config.ts",
    "build:package": "tsc -p tsconfig.package.json && cp -r src/migrations dist/migrations"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.1",
    "@flamecast/protocol": "workspace:*",
    "@flamecast/sdk": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.8",
    "vitest": "^4.1.0"
  }
}
