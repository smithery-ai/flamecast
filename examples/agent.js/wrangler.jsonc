{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "flamecast-agent-js",
  "account_id": "c4cf21d8a5e8878bc3c92708b1f80193",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-24",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "AcpRuntimeHubAgent",
        "class_name": "AcpRuntimeHubAgent",
      },
      {
        "name": "AcpSessionAgent",
        "class_name": "AcpSessionAgent",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AcpSessionAgent"],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["AcpRuntimeHubAgent"],
    },
  ],
  "worker_loaders": [{ "binding": "LOADER" }],
  "vars": {
    "AGENT_MODE": "gateway",
    "KEEP_RECENT_TURNS": "6",
    "MAX_CONTEXT_TOKENS": "1050000",
    "COMPACT_AT_CONTEXT_RATIO": "0.8",
    "CF_ACCOUNT_ID": "c4cf21d8a5e8878bc3c92708b1f80193",
    "CF_AI_GATEWAY": "smithery-agent",
    "CF_AI_MODEL": "openai/gpt-5.4",
  },
}
