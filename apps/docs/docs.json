{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Flamecast",
  "colors": {
    "primary": "#F97316",
    "light": "#FB923C",
    "dark": "#EA580C"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Use cases",
            "pages": [
              "guides/local-agents",
              "guides/cloud-agents",
              "guides/build-your-own-agent",
              "guides/subagents",
              "guides/slackbot",
              "guides/custom-ui"
            ]
          },
          {
            "group": "Going deeper",
            "pages": [
              "guides/architecture",
              "guides/configuration",
              "guides/storage",
              "guides/development"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "REST API",
            "pages": ["api-reference/introduction", "api-reference/endpoints"]
          },
          {
            "group": "WebSocket",
            "pages": ["api-reference/websocket"]
          },
          {
            "group": "Client SDK",
            "pages": ["api-reference/client-sdk"]
          }
        ]
      },
      {
        "tab": "RFCs",
        "groups": [
          {
            "group": "Proposals",
            "pages": [
              "rfcs/webhooks",
              "rfcs/setup-scripts",
              "rfcs/dockerfile-validation",
              "rfcs/prebuilt-images",
              "rfcs/queue-management",
              "rfcs/terminal-sessions",
              "rfcs/multi-session-websocket"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/anthropics/flamecast",
          "icon": "github"
        },
        {
          "anchor": "ACP spec",
          "href": "https://agentclientprotocol.com",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/anthropics/flamecast"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/anthropics/flamecast"
    }
  }
}
