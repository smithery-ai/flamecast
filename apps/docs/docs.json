{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Flamecast",
  "colors": {
    "primary": "#F97316",
    "light": "#FB923C",
    "dark": "#EA580C"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "development"]
          },
          {
            "group": "Core concepts",
            "pages": [
              "guides/architecture",
              "guides/acp-bridge",
              "guides/runtime-providers",
              "guides/storage",
              "guides/agent-templates"
            ]
          },
          {
            "group": "Configuration",
            "pages": ["guides/configuration"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "REST API",
            "pages": ["api-reference/introduction", "api-reference/endpoints"]
          },
          {
            "group": "WebSocket",
            "pages": ["api-reference/websocket"]
          },
          {
            "group": "Client SDK",
            "pages": ["api-reference/client-sdk"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/anthropics/flamecast",
          "icon": "github"
        },
        {
          "anchor": "ACP spec",
          "href": "https://agentclientprotocol.com",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/anthropics/flamecast"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/anthropics/flamecast"
    }
  }
}
