{
  "$schema": "https://turbo.build/schema.json",
  "futureFlags": { "experimentalObservability": true },
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build:package"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:package": {
      "dependsOn": ["^build:package"],
      "outputs": ["dist/**"]
    },
    "test": {
      "outputs": []
    },
    "test:api:coverage": {
      "outputs": ["coverage/**"]
    },
    "knip": {
      "outputs": []
    },
    "psql:generate": {
      "cache": false
    }
  }
}
